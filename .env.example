# OpenAI API Key for ChatGPT Deep Research
# Get yours at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-key-here

# Gemini API Key for image generation
# Get yours at https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here
# Cloudflare R2 CDN (optional — images will be saved locally if not set)
# Create an R2 bucket at https://dash.cloudflare.com → R2
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_ENDPOINT_URL=https://your-account-id.r2.cloudflarestorage.com
R2_BUCKET_NAME=your-bucket-name
R2_PUBLIC_URL=https://your-cdn-domain.com

# Apify API key for Amazon review scraping
# Get yours at https://console.apify.com/account/integrations
APIFY_API_KEY=your-apify-api-key-here

# Amazon session-backed scraper settings
AMAZON_PROFILE_DIR=.amazon-profile
AMAZON_STORAGE_STATE_PATH=.amazon-storage-state.json
AMAZON_MARKETPLACE=www.amazon.com
AMAZON_HEADLESS=false

# Amazon scraper rate limiting (optional — defaults shown)
AMAZON_MIN_PAGE_DELAY=3.0
AMAZON_MAX_PAGE_DELAY=8.0
AMAZON_MAX_RETRIES=3

# Proxy for Amazon scraper (optional — works without proxy, just higher block risk)
# Supports any residential proxy provider (Bright Data, IPRoyal, SmartProxy, etc.)
PROXY_SERVER=http://proxy-host:port
PROXY_USERNAME=your-proxy-username
PROXY_PASSWORD=your-proxy-password

# Google Shopping scraper settings
GOOGLE_HEADLESS=true
GOOGLE_MAX_REVIEW_PAGES=10
GOOGLE_DELAY_MS=3000
GOOGLE_TIMEOUT_MS=30000
GOOGLE_LOCALE=en
GOOGLE_COUNTRY=us
GOOGLE_STEALTH=true
GOOGLE_PROFILE_DIR=.google-profile

# Reddit API credentials (for reddit_scraper)
# Create a "script" app at https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=your-reddit-client-id
REDDIT_CLIENT_SECRET=your-reddit-client-secret
REDDIT_USER_AGENT=FunnelAgent/1.0 (research scraper)
