# Discord
DISCORD_BOT_TOKEN=
DISCORD_APPLICATION_ID=
DISCORD_PUBLIC_KEY=

# Anthropic (for Claude Agent SDK)
ANTHROPIC_API_KEY=

# Paths (flexible for local dev or VPS/Docker)
FUNNEL_AGENT_REPO_DIR=/srv/FunnelAgent
FUNNEL_AGENT_OUTPUT_DIR=/srv/FunnelAgent/output
FUNNEL_AGENT_DB_PATH=/srv/FunnelAgent/discord_bot/data/bot.db
FUNNEL_AGENT_LOG_DIR=/srv/FunnelAgent/discord_bot/logs

# API Keys (passed through to agent environment)
OPENAI_API_KEY=
GEMINI_API_KEY=

# CDN (optional)
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ENDPOINT_URL=
R2_BUCKET_NAME=
R2_PUBLIC_URL=

# Auto-update
GIT_AUTO_UPDATE=true
GIT_UPDATE_INTERVAL=3600
